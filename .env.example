# Nextcloud CalDAV connection.
# CALDAV_URL is the DAV endpoint root, e.g. https://cloud.example.com/remote.php/dav/
# Use an app password (Settings -> Security -> Devices & sessions), never your account password.
# Must be https:// - the server refuses to start with a http:// URL unless it
# points at a local address (localhost/127.0.0.1/::1) or
# NEXTCLOUD_ALLOW_INSECURE_HTTP=1 is set (see below), since http:// sends this
# app password in cleartext Basic Auth on every request.
NEXTCLOUD_CALDAV_URL=https://cloud.example.com/remote.php/dav/
NEXTCLOUD_USERNAME=your-nextcloud-username
NEXTCLOUD_APP_PASSWORD=your-nextcloud-app-password

# Only needed if NEXTCLOUD_CALDAV_URL above is genuinely http:// and does NOT
# point at localhost/127.0.0.1/::1 (e.g. an internal-network Nextcloud without
# its own TLS). WARNING: this sends your Nextcloud app password in cleartext
# on every request - do not set this for a real deployment.
# NEXTCLOUD_ALLOW_INSECURE_HTTP=1

# OAuth 2.1 authentication (PersonalAuthProvider). The server is a Claude
# custom connector, authenticated via OAuth + PKCE instead of a static token.

# Required. The exact public URL clients (Claude) use to reach this server -
# must match precisely, including scheme, or the OAuth discovery/redirect
# flow will fail. Locally this is http://127.0.0.1:8000; in production it's
# your public Tailscale Funnel HTTPS URL, e.g.
# https://your-host.your-tailnet.ts.net
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Password gate on the OAuth /authorize step. Required (the server refuses
# to start without it) whenever PUBLIC_BASE_URL above is not localhost, or
# MCP_HOST below is bound to a non-local address (e.g. 0.0.0.0) - the
# redirect-domain allow-list alone does NOT stop a scripted client from
# registering itself via the (intentionally open) DCR endpoint and
# self-issuing a valid access token, since it never has to actually control
# the redirect domain, only claim one that's on the allow-list. This password
# is the only real gate once the server is reachable from the public
# internet (Tailscale Funnel). Not needed for local-only use
# (PUBLIC_BASE_URL=http://127.0.0.1:... or http://localhost:... AND
# MCP_HOST=127.0.0.1/localhost).
#
# Uncomment and set this to a long random secret for any non-localhost
# deployment - the server will refuse to start with the placeholder value
# below, and will also refuse to start with no password at all once it's
# reachable from anywhere but localhost. Generate a value with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# MCP_OAUTH_PASSWORD=change-me-to-a-long-random-password

# Optional, comma-separated. Only these domains (and subdomains) may
# complete the OAuth redirect. Default when unset: claude.ai,claude.com for a
# non-localhost PUBLIC_BASE_URL (a "localhost" entry in a public deployment's
# allow-list can never be reached by a real OAuth redirect anyway); for a
# localhost PUBLIC_BASE_URL, claude.ai,claude.com,localhost.
# MCP_OAUTH_ALLOWED_REDIRECT_DOMAINS=claude.ai,claude.com,localhost

# Optional. How long issued access tokens are valid, in seconds.
# Default: 2592000 (30 days). Refresh tokens do not expire.
# MCP_OAUTH_ACCESS_TOKEN_EXPIRY_SECONDS=2592000

# Optional. Directory where OAuth client registrations and tokens are
# persisted (oauth_tokens.json) so they survive server restarts.
# Default: .oauth-state (relative to the working directory).
# MCP_OAUTH_STATE_DIR=.oauth-state

# Networking (optional, defaults shown). The server only needs to bind to
# a local port - tailscale funnel handles TLS termination in front of it.
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Set to 1 to enable integration tests that hit the real Nextcloud instance
# configured above (see README for details). Leave unset for unit tests only.
# RUN_INTEGRATION_TESTS=1

# Name of an existing (ideally disposable) task list to use for integration
# tests. Tasks are created and deleted in this list during the test run.
# INTEGRATION_TEST_LIST=Test
