# Nextcloud CalDAV connection.
# CALDAV_URL is the DAV endpoint root, e.g. https://cloud.example.com/remote.php/dav/
# Use an app password (Settings -> Security -> Devices & sessions), never your account password.
NEXTCLOUD_CALDAV_URL=https://cloud.example.com/remote.php/dav/
NEXTCLOUD_USERNAME=your-nextcloud-username
NEXTCLOUD_APP_PASSWORD=your-nextcloud-app-password

# Static bearer token this MCP server requires on every request
# (Authorization: Bearer <token>). Generate one long random value, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=change-me-to-a-long-random-token

# Networking (optional, defaults shown). The server only needs to bind to
# a local port - tailscale serve handles TLS termination in front of it.
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Set to 1 to enable integration tests that hit the real Nextcloud instance
# configured above (see README for details). Leave unset for unit tests only.
# RUN_INTEGRATION_TESTS=1

# Name of an existing (ideally disposable) task list to use for integration
# tests. Tasks are created and deleted in this list during the test run.
# INTEGRATION_TEST_LIST=Test
